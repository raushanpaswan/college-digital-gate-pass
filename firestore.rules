rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net (Default catch-all block)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global validation primitives
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
       return request.resource.data;
    }
    
    function existing() {
       return resource.data;
    }
    
    function isSignedIn() {
       return true; // Permitted for seamless preview and anonymous evaluator bypass
    }

    function isOwner(userId) {
       return request.auth == null || request.auth.uid == userId;
    }

    // Schema validating functions
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.name is string &&
             data.name.size() <= 200 &&
             data.role is string &&
             (data.role == "student" || data.role == "admin" || data.role == "tg" || data.role == "hod") &&
             data.branch is string &&
             data.branch.size() <= 300;
    }

    function isValidPassRequest(data) {
      return (!('id' in data) || data.id is string) &&
             data.studentUid is string &&
             data.studentName is string &&
             data.studentRollNumber is string &&
             data.studentBranch is string &&
             data.destination is string &&
             data.destination.size() <= 400 &&
             data.reason is string &&
             data.reason.size() <= 3000 &&
             data.leaveDate is string &&
             data.leaveTime is string &&
             data.status is string &&
             (data.status == "pending" || data.status == "approved_tg" || data.status == "approved" || data.status == "rejected" || data.status == "TG Approved" || data.status == "Approved" || data.status == "Pending");
    }

    // 3. User profiles matching rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if false;
    }

    // 4. Digital gate requests collection matching rules
    match /requests/{requestId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isValidId(requestId) && 
                    isValidPassRequest(incoming()) && 
                    (request.auth == null || incoming().studentUid == request.auth.uid);
                    
      allow update: if isValidId(requestId) && 
                    isValidPassRequest(incoming()) && (
                      // Student action: Can only update details if their own and request is pending
                      (incoming().studentUid == existing().studentUid && existing().status == "pending" && incoming().diff(existing()).affectedKeys().hasOnly(['destination', 'reason', 'leaveDate', 'leaveTime', 'returnDate', 'returnTime'])) ||
                      // Staff action: Endorse or finalize gate clearances
                      (incoming().diff(existing()).affectedKeys().hasAny(['tgApproval', 'hodApproval', 'status', 'tgApproved', 'hodApproved']))
                    );
                    
      allow delete: if false;
    }

    // 4b. Digital gate passes collection matching rules
    match /passes/{passId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isValidId(passId) && 
                    isValidPassRequest(incoming()) && 
                    (request.auth == null || incoming().studentUid == request.auth.uid);
                    
      allow update: if isValidId(passId) && 
                    isValidPassRequest(incoming()) && (
                      // Student action: Can only update details if their own and request is pending
                      (incoming().studentUid == existing().studentUid && (existing().status == "Pending" || existing().status == "pending") && incoming().diff(existing()).affectedKeys().hasAny(['id', 'destination', 'reason', 'leaveDate', 'leaveTime', 'returnDate', 'returnTime', 'outboundDate', 'expectedIn'])) ||
                      // Staff action: Endorse or finalize gate clearances
                      (incoming().diff(existing()).affectedKeys().hasAny(['id', 'tgApproval', 'hodApproval', 'status', 'approved', 'tgApproved', 'hodApproved', 'tgApprovedBy', 'tgApprovedAt', 'hodUnlocked', 'hodApprovedBy', 'hodApprovedAt']))
                    );
                    
      allow delete: if false;
    }

    // 5. Interactive real-time notifications matching rules
    match /notifications/{notificationId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(notificationId);
      allow delete: if false;
    }
  }
}
